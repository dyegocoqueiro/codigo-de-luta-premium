rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email is string;
    }

    function approved() {
      return signedIn()
        && exists(/databases/$(database)/documents/approvedEmails/$(request.auth.token.email))
        && get(/databases/$(database)/documents/approvedEmails/$(request.auth.token.email)).data.approved != false;
    }

    match /approvedEmails/{email} {
      allow get: if true;
      allow list: if false;
      allow write: if false;
    }

    match /accessRequests/{email} {
      allow get: if signedIn() && request.auth.token.email == email;
      allow list, delete: if false;
      allow create, update: if signedIn()
        && request.auth.token.email == email
        && request.resource.data.email == email
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.keys().hasOnly([
          "email",
          "uid",
          "name",
          "phone",
          "source",
          "page",
          "status",
          "requestedAt",
          "updatedAt"
        ]);
    }

    match /users/{userId}/{document=**} {
      allow read, write: if approved() && request.auth.uid == userId;
    }
  }
}
